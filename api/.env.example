# Server
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
LOG_LEVEL=debug
METRICS_ENABLED=true

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=earn4u
DATABASE_PASSWORD=earn4u_secret
DATABASE_NAME=earn4u_db
DATABASE_SSL=false
DATABASE_POOL_MAX=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=earn4u-api

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT — MUST change in production (min 32 chars)
JWT_ACCESS_SECRET=local-dev-access-secret-minimum-32-chars
JWT_REFRESH_SECRET=local-dev-refresh-secret-minimum-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# S3 / MinIO (local)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=earn4u_minio
AWS_SECRET_ACCESS_KEY=earn4u_minio_secret
AWS_S3_BUCKET=earn4u-media
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_FORCE_PATH_STYLE=true

# SMTP / Mailpit (local)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@earn4u.com

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# LiveKit (Phase 2)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://localhost:7880

# Payments (Phase 5)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase (Phase 10)
FCM_PROJECT_ID=

# Observability
SENTRY_DSN=
